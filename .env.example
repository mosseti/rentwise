# Local development defaults. For production, use .env.production.example as your guide.
SECRET_KEY=dev-secret-key-change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=
DATABASE_URL=

# Free testing map/search stack. No Google Maps key is required for this version.
MAP_PROVIDER=osm
GEOCODER_PROVIDER=nominatim

# Free-tier AI testing through Gemini.
# Without this key, the assistant still runs in local RentWise database fallback mode.
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-3.5-flash

# Uploaded images. In production, set this to your persistent disk/volume path.
MEDIA_ROOT=media
MEDIA_URL=/media/

# Security. Keep these false locally.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
